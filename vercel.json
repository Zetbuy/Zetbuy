{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/app.js", "destination": "/public/app.js" },
    { "source": "/style.css", "destination": "/public/style.css" },
    { "source": "/marketplace.js", "destination": "/public/marketplace.js" },
    { "source": "/marketplace.css", "destination": "/public/marketplace.css" },
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/(.*)", "destination": "/public/marketplace.html" }
  ]
}
